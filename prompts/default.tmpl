    },
    "action": {
        "name": "Tool name ({{.ToolNames}})",
        "reason": "Concise reason for this exact next step, based on the current evidence gap or supported guide candidate (not more than 100 words)",
        "goal": "What this single next action is intended to decide or verify",
        "target": {
            "resource": "The exact resource kind targeted by this command",
            "namespace": "The exact namespace when the user or evidence identifies one",
